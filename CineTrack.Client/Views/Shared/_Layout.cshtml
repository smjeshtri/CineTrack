<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/CineTrack.Client.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
</head>
<body style="margin:0; padding:0; background:#0a0a0a;">

    <!-- Navbar -->
    <nav class="navbar navbar-expand-lg navbar-dark" style="background-color:#0a0a0a; border-bottom:1px solid #222;">
        <div class="container">
            <a class="navbar-brand fw-bold ct-nav-link" style="color:#D4A017; letter-spacing:2px;"
               asp-controller="Home" asp-action="Index">CINETRACK</a>
            <div class="d-flex gap-4 align-items-center">
                <a asp-controller="Home" asp-action="Index"
                   class="text-secondary text-decoration-none ct-nav-link">Home</a>
                <a asp-controller="Movie" asp-action="Index"
                   class="text-secondary text-decoration-none ct-nav-link">My List</a>
                <a asp-controller="Auth" asp-action="Users"
                   class="text-secondary text-decoration-none ct-nav-link">Users</a>
                <a asp-controller="Auth" asp-action="Login" class="btn btn-sm ct-btn-gold"
                   style="background:#D4A017; color:#000; font-weight:500;">Sign In</a>
            </div>
        </div>
    </nav>

    <!-- Page Content -->
    @RenderBody()

    <!-- Footer -->
    <footer style="background:#0a0a0a; border-top:1px solid #1a1a1a;" class="text-center py-3">
        <p class="text-secondary mb-0" style="font-size:13px;">
            &copy; 2026 CineTrack — built with ASP.NET Core
        </p>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>