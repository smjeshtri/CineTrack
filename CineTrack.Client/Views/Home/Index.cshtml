@{
    ViewData["Title"] = "CineTrack";
}

<!-- Hero Section -->
<div style="background:#0a0a0a;" class="py-5 text-center">
    <div class="container py-4">
        <h1 class="display-4 fw-bold text-white">Your movies.<br>
            <span style="color:#D4A017;">Tracked. Shared. Loved.</span>
        </h1>
        <p class="text-secondary mt-3 mb-4 fs-5">Build your personal watchlist, share it with friends,<br>and never lose track of what to watch next.</p>
        <div class="mx-auto p-4 rounded-3" style="background:#1a1a1a; border:1px solid #333; max-width:600px;">
            <div class="input-group">
                <input type="text" class="form-control bg-dark text-white border-secondary" placeholder="Search for a movie to add...">
                <button class="btn ct-btn-gold" style="background:#D4A017; color:#000;">Track It</button>
            </div>
        </div>
    </div>
</div>

<!-- Feature Cards -->
<div style="background:#111;" class="py-5">
    <div class="container">
        <div class="row g-4 justify-content-center">
            <div class="col-md-4">
                <div class="p-4 rounded-3 h-100 ct-card" style="background:#1a1a1a; border:1px solid #2a2a2a;">
                    <i class="bi bi-collection-play fs-3" style="color:#D4A017;"></i>
                    <h5 class="text-white mt-3">Build your list</h5>
                    <p class="text-secondary">Add any movie and organize your personal watchlist</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="p-4 rounded-3 h-100 ct-card" style="background:#1a1a1a; border:1px solid #2a2a2a;">
                    <i class="bi bi-share fs-3" style="color:#D4A017;"></i>
                    <h5 class="text-white mt-3">Share with friends</h5>
                    <p class="text-secondary">Send your watchlist via a single link</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="p-4 rounded-3 h-100 ct-card" style="background:#1a1a1a; border:1px solid #2a2a2a;">
                    <i class="bi bi-star fs-3" style="color:#D4A017;"></i>
                    <h5 class="text-white mt-3">Rate & review</h5>
                    <p class="text-secondary">Leave personal notes on every movie you watch</p>
                </div>
            </div>
        </div>
    </div>
</div>